{
  "info": {
    "name": "Auth Service - Complete API Collection",
    "description": "Complete Postman collection for testing the Auth Service microservice. Includes authentication flow, user management, and token validation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔐 Authentication",
      "description": "User registration, login, and token management",
      "item": [
        {
          "name": "📝 Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.environment.set('userId', jsonData.id);",
                  "    pm.environment.set('userEmail', jsonData.email);",
                  "    pm.test('User registered successfully', () => {",
                  "        pm.expect(jsonData.id).to.exist;",
                  "        pm.expect(jsonData.name).to.equal('John Doe');",
                  "        pm.expect(jsonData.email).to.equal('john@example.com');",
                  "        pm.expect(jsonData.enabled).to.be.true;",
                  "        pm.expect(jsonData.emailVerified).to.be.false;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate unique email for testing",
                  "const timestamp = Date.now();",
                  "const randomEmail = `user_${timestamp}@example.com`;",
                  "pm.environment.set('randomEmail', randomEmail);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePassword@123\",\n  \"passwordConfirmation\": \"SecurePassword@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "description": "Register a new user account. Password must be at least 8 characters."
          },
          "response": []
        },
        {
          "name": "🔑 Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.environment.set('accessToken', jsonData.accessToken);",
                  "    pm.environment.set('refreshToken', jsonData.refreshToken);",
                  "    pm.environment.set('tokenType', jsonData.type);",
                  "    pm.environment.set('expiresIn', jsonData.expiresIn);",
                  "    ",
                  "    pm.test('Login successful', () => {",
                  "        pm.expect(jsonData.accessToken).to.exist;",
                  "        pm.expect(jsonData.refreshToken).to.exist;",
                  "        pm.expect(jsonData.type).to.equal('Bearer');",
                  "        pm.expect(jsonData.expiresIn).to.be.a('number');",
                  "    });",
                  "} else {",
                  "    pm.test('Check credentials', () => {",
                  "        pm.expect(pm.response.code).to.equal(200);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePassword@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Authenticate user and retrieve JWT access token and refresh token. Automatically saves tokens for use in other requests."
          },
          "response": []
        },
        {
          "name": "🔄 Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.environment.set('accessToken', jsonData.accessToken);",
                  "    pm.test('Token refreshed successfully', () => {",
                  "        pm.expect(jsonData.accessToken).to.exist;",
                  "        pm.expect(jsonData.type).to.equal('Bearer');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "refresh"
              ]
            },
            "description": "Refresh an expired access token using the refresh token. Automatically updates the access token for subsequent requests."
          },
          "response": []
        },
        {
          "name": "🚪 Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.test('Logout successful', () => {",
                  "        pm.expect(jsonData.message).to.exist;",
                  "    });",
                  "    ",
                  "    // Clear tokens after logout",
                  "    pm.environment.set('accessToken', '');",
                  "    pm.environment.set('refreshToken', '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "logout"
              ]
            },
            "description": "Logout user and invalidate refresh token. Requires valid access token."
          },
          "response": []
        },
        {
          "name": "✅ Validate Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.test('Token validation response received', () => {",
                  "        pm.expect(jsonData.valid).to.be.a('boolean');",
                  "        if (jsonData.valid) {",
                  "            pm.expect(jsonData.userId).to.exist;",
                  "            pm.expect(jsonData.email).to.exist;",
                  "        }",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accessToken\": \"{{accessToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/validate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "validate"
              ]
            },
            "description": "Validate an access token. Returns token validity, user info, roles, and permissions."
          },
          "response": []
        }
      ]
    },
    {
      "name": "🔒 Password Management",
      "description": "Password reset and recovery flows",
      "item": [
        {
          "name": "📧 Forgot Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.test('Forgot password request sent', () => {",
                  "        pm.expect(jsonData.message).to.exist;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/forgot-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "forgot-password"
              ]
            },
            "description": "Request password reset. Sends reset token to email address."
          },
          "response": []
        },
        {
          "name": "🔐 Reset Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.test('Password reset successful', () => {",
                  "        pm.expect(jsonData.message).to.exist;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resetToken\": \"{{resetToken}}\",\n  \"newPassword\": \"NewPassword@456\",\n  \"passwordConfirmation\": \"NewPassword@456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/reset-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "reset-password"
              ]
            },
            "description": "Reset user password using reset token received via email. New password must be at least 8 characters."
          },
          "response": []
        }
      ]
    },
    {
      "name": "📊 Health & Status",
      "description": "System health checks",
      "item": [
        {
          "name": "💚 Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            },
            "description": "Check if the service is running and healthy."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "Base URL for the Auth Service API"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string",
      "description": "JWT access token (auto-populated after login)"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string",
      "description": "Refresh token (auto-populated after login)"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string",
      "description": "Current user ID (auto-populated after registration)"
    },
    {
      "key": "userEmail",
      "value": "",
      "type": "string",
      "description": "Current user email (auto-populated after registration)"
    },
    {
      "key": "tokenType",
      "value": "Bearer",
      "type": "string",
      "description": "Type of token (usually Bearer)"
    },
    {
      "key": "expiresIn",
      "value": "",
      "type": "string",
      "description": "Token expiration time in seconds (auto-populated after login)"
    },
    {
      "key": "resetToken",
      "value": "",
      "type": "string",
      "description": "Password reset token (obtained from email after forgot-password request)"
    }
  ]
}
